# SUIT PRO EPOS - Environment Configuration Template
# Copy this file to .env and update values with YOUR actual values
# DO NOT COMMIT .env FILE TO GIT - ONLY THIS FILE

# ============================================
# MASTER OWNER CREDENTIALS (CHANGE IN PRODUCTION)
# ============================================
MASTER_USERNAME=Rumel
MASTER_PASSWORD=<YOUR_STRONG_PASSWORD_HERE>

# ============================================
# JWT TOKEN SECURITY
# ============================================
JWT_SECRET=<YOUR_JWT_SECRET_KEY_HERE>
JWT_EXPIRY=24h

# ============================================
# APPLICATION ENVIRONMENT
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# DATABASE CONFIGURATION
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=u473489494_suitproepos
MYSQL_PASSWORD=<YOUR_DATABASE_PASSWORD>
MYSQL_DATABASE=u473489494_suitproepos
DATABASE_URL=mysql://u473489494_suitproepos:<password>@localhost:3306/u473489494_suitproepos

# ============================================
# THERMAL PRINTER CONFIGURATION
# ============================================
PRINTER_TYPE=bluetooth
PRINTER_WIDTH=58mm
PRINTER_VENDOR_ID=0x0483
PRINTER_PRODUCT_ID=0x0110

# ============================================
# QUCOM BTD THERMAL PRINTER SETTINGS
# ============================================
# Qucom BTD (Bluetooth Thermal Device) Configuration
# Port: Windows COM3, Linux /dev/ttyUSB0, macOS /dev/tty.usbserial-*
QUCOM_BTD_PORT=/dev/ttyUSB0
QUCOM_BTD_BAUD_RATE=9600
QUCOM_BTD_TIMEOUT_MS=5000
QUCOM_BTD_ENABLED=true
QUCOM_BTD_MODEL=Qucom-BTD-58
QUCOM_BTD_PAPER_WIDTH=58

# ============================================
# BACKUP SETTINGS
# ============================================
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_DIR=/var/backups/suitpro

# ============================================
# SYSTEM SETTINGS
# ============================================
SHOW_TAX_BREAKDOWN=true
SHOW_SALESPERSON=true
SHOW_SIZE_COLOR=true
VAT_STANDARD_RATE=20
HEADER_GREETING=THANK YOU FOR SHOPPING WITH SUIT PRO LONDON
FOOTER_GREETING=BESPOKE TAILORING & READY-TO-WEAR - SAVILE ROW

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info
LOG_FILE=suitpro_system_audits.log

# ============================================
# SECURITY SETTINGS
# ============================================
DEVICE_HEARTBEAT_TIMEOUT_MS=45000
DEVICE_CLEANUP_INTERVAL_MS=60000
STALE_DEVICE_THRESHOLD_MS=300000
DEVICE_HEALTH_CHECK_ENABLED=true
